# ---------------------------------------------------------------------------
# Frontend environment (Vite)
# ---------------------------------------------------------------------------
# Only variables prefixed MEDPLUM_ / GOOGLE_ / RECAPTCHA_ are exposed to the
# browser (see envPrefix in vite.config.ts). Copy this file to `.env`.

# Base URL of your Medplum server.
MEDPLUM_BASE_URL=https://api.medplum.com/ # Or http://localhost:8103/ for localhost

# Optional: OAuth client id for a specific ClientApplication.
MEDPLUM_CLIENT_ID= # Optional

# ---------------------------------------------------------------------------
# Voice intake bot secrets — NOT set here.
# ---------------------------------------------------------------------------
# The Bedrock (intake-chat) and Deepgram (deepgram-token) bots read these from
# Medplum PROJECT SECRETS, not from this file — they run server-side in the bot
# sandbox and must never reach the browser. Set them in the Medplum app under
# Admin -> Project -> Secrets:
#
#   AWS_REGION             e.g. us-east-1
#   AWS_ACCESS_KEY_ID      IAM key with Bedrock InvokeModel access
#   AWS_SECRET_ACCESS_KEY
#   BEDROCK_MODEL_ID       default openai.gpt-oss-20b-1:0
#                          (some regions need the us. inference-profile prefix,
#                           e.g. us.openai.gpt-oss-20b-1:0)
#   DEEPGRAM_API_KEY       used only to mint short-lived browser tokens
#   DEEPGRAM_VOICE_ID      optional Aura TTS voice (default aura-2-thalia-en)
#
# Also enable model access for openai.gpt-oss-20b in the AWS Bedrock console.
